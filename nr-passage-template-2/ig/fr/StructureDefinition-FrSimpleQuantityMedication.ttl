       fhir:ElementDefinition.short [ fhir:value "A fixed quantity (no comparator) with UCUM or EDQM code or no code" ] ;
       fhir:ElementDefinition.definition [ fhir:value "The comparator is not used on a SimpleQuantity. The code SHALL be a UCUM or EDQM code if used." ] ;
       fhir:ElementDefinition.comment [ fhir:value "The context of use may frequently define what kind of quantity this is and therefore what kind of units can be used. The context of use explicitely excludes the use of the simpleQuantity \"comparator\" element." ] ;
       fhir:ElementDefinition.min [ fhir:value "0"^^xsd:nonNegativeInteger ] ;
