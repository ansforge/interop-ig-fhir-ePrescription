     ]
  ] ;
  fhir:StructureDefinition.purpose [ fhir:value "décrit le médicament figurant dans une ressource Interop'Santé (fr) MedicationStatement (Bilan Médicamenteux, Conciliation) ou MedicationRequest (prescription)"] ;
